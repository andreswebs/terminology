{"schema_version":1,"name":"validate","usage":"validate a TBX file against the supported subset","flags":[{"name":"strict","type":"bool","usage":"promote unknown elements and unresolved IDREFs to errors"},{"name":"fields","type":"string","aliases":["F"],"usage":"comma-separated dotted paths to include"},{"name":"help","type":"bool","aliases":["h"],"usage":"show help"}],"commands":[{"name":"help","usage":"Shows a list of commands or help for one command","flags":null}],"envelope":{"fields":[{"name":"schema_version","type":"number"},{"name":"ok","type":"boolean"},{"name":"concepts","type":"number"},{"name":"languages","type":"array"},{"name":"warnings","type":"array","children":[{"name":"code","type":"string"},{"name":"message","type":"string"},{"name":"concept_id","type":"string"},{"name":"line","type":"number"},{"name":"column","type":"number"}]}]},"exit_codes":[0,1,2,3,65],"error_codes":[{"code":"apply_validation_failed","exit_code":1,"message":"apply payload failed validation; no changes written","hint":"fix per-concept errors in failures[] and retry"},{"code":"conflicting_verbosity","exit_code":2,"message":"pass at most one of --verbose, --debug, --quiet","hint":"--verbose, --debug, and --quiet are mutually exclusive"},{"code":"dangling_crossref","exit_code":65,"message":"write would leave dangling cross-references","hint":"remove or update cross-references before removing the target concept, or use --force"},{"code":"duplicate_id","exit_code":65,"message":"concept ID already exists","hint":"use 'concept update' to modify an existing concept"},{"code":"input_too_large","exit_code":2,"message":"input exceeds maximum size","hint":"split the input into smaller files or batches"},{"code":"invalid_field","exit_code":2,"message":"unknown field path","hint":"see `terminology schema --command CMD` for valid paths"},{"code":"invalid_id","exit_code":65,"message":"derived concept ID is empty","hint":"supply an explicit --id when the term has no Latin/numeric characters"},{"code":"invalid_id","exit_code":65,"message":"concept ID contains rejected characters","hint":"concept IDs must not contain control characters, path traversals, percent-encoded segments, or query parameters"},{"code":"invalid_input","exit_code":65,"message":"XML nesting depth exceeds maximum of 256 levels","hint":"nesting_too_deep"},{"code":"invalid_input","exit_code":65,"message":"stdin payload is malformed or unsupported","hint":"check the JSON payload structure; use 'terminology schema' for the expected shape"},{"code":"invalid_input","exit_code":65,"message":"dangerous DOCTYPE declaration","hint":"only bare \u003c!DOCTYPE tbx\u003e is accepted; entity declarations and external IDs are rejected"},{"code":"invalid_lang_tag","exit_code":65,"message":"language tag is invalid","hint":"language tags must be well-formed BCP 47 (e.g. en, es, he, pt-BR)"},{"code":"invalid_path","exit_code":65,"message":"file path contains rejected characters or escapes the sandbox","hint":"paths must not contain .., percent-encoded segments, or query parameters"},{"code":"invalid_term","exit_code":65,"message":"term contains rejected characters","hint":"terms must not contain control characters"},{"code":"language_required","exit_code":2,"message":"language not specified","hint":"pass --source-lang/--target-lang or add 'lang: LANG' to frontmatter"},{"code":"merge_replace_mutex","exit_code":2,"message":"pass exactly one of --merge or --replace","hint":"--merge and --replace are mutually exclusive"},{"code":"merge_replace_required","exit_code":2,"message":"pass exactly one of --merge or --replace","hint":"either --merge or --replace must be supplied"},{"code":"no_subcommand","exit_code":2,"message":"no subcommand specified","hint":"run 'terminology concept --help' for available subcommands"},{"code":"no_subcommand","exit_code":2,"message":"no subcommand specified","hint":"run 'terminology term --help' for available subcommands"},{"code":"no_subcommand","exit_code":2,"message":"no subcommand specified","hint":"run 'terminology --help' for available commands"},{"code":"no_tbx_path","exit_code":2,"message":"no TBX file path provided","hint":"set --tbx or TERMINOLOGY_TBX"},{"code":"not_found","exit_code":65,"message":"concept not found","hint":"use 'concept add' to create a new concept, or check the ID"},{"code":"tbx_locked","exit_code":3,"message":"TBX file is locked by another process","hint":"another terminology process is writing; retry"},{"code":"unsupported_dialect","exit_code":65,"message":"unsupported TBX dialect","hint":"supported: TBX-Linguist"},{"code":"validation_error","exit_code":65,"message":"TBX validation failed","hint":"check the TBX file structure and content"}]}
